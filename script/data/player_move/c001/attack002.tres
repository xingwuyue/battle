[gd_resource type="Resource" script_class="PlayerMoveData" load_steps=5 format=3]

[ext_resource type="Script" path="res://script/data/player_move/player_move_data.gd" id="1_move"]
[ext_resource type="Script" path="res://script/data/player_move/player_move_phase_window.gd" id="2_phase"]
[ext_resource type="Resource" path="res://script/data/player_move/c001/attack002_motion.tres" id="3_motion"]

[sub_resource type="Resource" script_class="PlayerMovePhaseWindow" id="1_startup"]
script = ExtResource("2_phase")
phase_name = &"startup"
start_ratio = 0.0
end_ratio = 0.18

[sub_resource type="Resource" script_class="PlayerMovePhaseWindow" id="2_active"]
script = ExtResource("2_phase")
phase_name = &"active"
start_ratio = 0.18
end_ratio = 0.45

[sub_resource type="Resource" script_class="PlayerMovePhaseWindow" id="3_recovery"]
script = ExtResource("2_phase")
phase_name = &"recovery"
start_ratio = 0.45
end_ratio = 1.0

[resource]
script = ExtResource("1_move")
move_id = &"attack002"
display_name = "Attack 002"
input_command = &"light_attack"
priority = 100
animation_name = &"attack002"
required_prev_move_id = &"attack001"
required_phase = &"combo_window"
root_motion_enabled = true
root_motion_curve = ExtResource("3_motion")
phase_windows = [SubResource("1_startup"), SubResource("2_active"), SubResource("3_recovery")]
tags = PackedStringArray("ground_attack", "combo")
